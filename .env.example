# Copy to .env and fill in locally or on your production server.
# Never commit .env to Git.

# Required for chat
OPENAI_API_KEY=

# Optional — mobile alerts when someone schedules an interview
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# Optional — public contact shown on the live site only
CONTACT_EMAIL=
CONTACT_PHONE=
WHATSAPP_NUMBER=

# Optional — defaults shown below if unset
LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
GITHUB_URL=https://github.com/your-username

# Resume — paste the full URL copied from Cloudinary Media Library (PDF or DOCX)
RESUME_URL=

# Optional — only if you are NOT using RESUME_URL above
# Find these at: Cloudinary Dashboard → Home → Product environment credentials
# CLOUDINARY_CLOUD_NAME=          # short name, e.g. dhy0jccgg (from your URL)
# CLOUDINARY_API_KEY=             # shown on dashboard
# CLOUDINARY_API_SECRET=          # click the eye icon to reveal
# CLOUDINARY_RESUME_PUBLIC_ID=    # Media Library → click file → Public ID field

# Optional
GOOGLE_PLACES_API_KEY=
